{
  "name": "chronicle",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "vercel-dev": "npx vercel dev",
    "cron:check": "tsx --env-file=.env scripts/runCron.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src api --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
